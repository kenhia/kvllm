# kvllm service config — copy to deploy/kvllm.env (gitignored) and edit.
# Read by the systemd unit (EnvironmentFile) and the kvllm.registry serve path.

# Which model the service serves (a key from models.toml — see `just models-list`).
KVLLM_MODEL_KEY=qwen2.5-7b-instruct

# OpenAI-compatible port.
KVLLM_PORT=8000

# Fraction of the 32 GB the engine may use.
KVLLM_GPU_UTIL=0.90

# Only needed for gated models (e.g. llama-3.1-8b-instruct). Leave unset otherwise.
# HF_TOKEN=hf_xxx

# --- helper web app (kvllm-helper.service) ---
# Port the dashboard binds (0.0.0.0). Reach it at http://<host>:<port>/.
KVLLM_HELPER_PORT=8800
# Shared secret required for control actions (switch/restart/stop). UNSET = control disabled.
# Generate one: `openssl rand -hex 16`
# KVLLM_HELPER_TOKEN=

# Bind address for vllm serve. Loopback: remote access is via tailscale serve
# (https://kai.encke-wahoo.ts.net:8000 -> localhost:8000); 0.0.0.0 would collide
# with tailscaled on the next restart (EADDRINUSE).
KVLLM_HOST=127.0.0.1
