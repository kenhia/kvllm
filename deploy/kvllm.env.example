# kvllm service config — copy to deploy/kvllm.env (gitignored) and edit.
# Read by the systemd unit (EnvironmentFile) and the kvllm.registry serve path.

# Which model the service serves (a key from models.toml — see `just models-list`).
KVLLM_MODEL_KEY=qwen2.5-7b-instruct

# OpenAI-compatible port.
KVLLM_PORT=8000

# Fraction of the 32 GB the engine may use.
KVLLM_GPU_UTIL=0.90

# Only needed for gated models (e.g. llama-3.1-8b-instruct). Leave unset otherwise.
# HF_TOKEN=hf_xxx
